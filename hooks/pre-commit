#!/bin/bash
set -e

TOTAL=5
FAILED=0
REPORT_FILE=$(mktemp /tmp/security-hook-report.XXXXXX)

echo "🔒 Running security checks before commit..."

# --- 1. Gitleaks: Secret scanning ---
echo ""
echo "🔍 [1/$TOTAL] Running Gitleaks (secret scanning)..."
if ! command -v gitleaks &> /dev/null; then
    echo "⚠️  gitleaks not found. Install: brew install gitleaks"
else
    GITLEAKS_OPTS="--staged --no-banner --report-format json --report-path $REPORT_FILE.gitleaks"
    [ -f ".gitleaks.toml" ] && GITLEAKS_OPTS="$GITLEAKS_OPTS --config .gitleaks.toml"
    if ! gitleaks protect $GITLEAKS_OPTS; then
        echo "❌ Gitleaks found secrets:"
        echo "┌──────────────────────────────────────────────────────────"
        # Parse JSON report for details
        if [ -f "$REPORT_FILE.gitleaks" ] && command -v python3 &>/dev/null; then
            python3 -c "
import json, sys
try:
    data = json.load(open('$REPORT_FILE.gitleaks'))
    for i, leak in enumerate(data, 1):
        print(f\"│ Finding #{i}\")
        print(f\"│   Rule:     {leak.get('RuleID', 'unknown')}\")
        print(f\"│   File:     {leak.get('File', 'unknown')}\")
        print(f\"│   Line:     {leak.get('StartLine', '?')}\")
        print(f\"│   Secret:   {leak.get('Match', '')[:40]}...\")
        print(f\"│   Severity: HIGH\")
        print('│')
except: pass
"
        fi
        echo "└──────────────────────────────────────────────────────────"
        FAILED=1
    else
        echo "✅ Gitleaks: No secrets detected."
    fi
fi

# --- 2. Checkov: IaC security scanning ---
echo ""
echo "🔍 [2/$TOTAL] Running Checkov (IaC security scanning)..."
if ! command -v checkov &> /dev/null; then
    echo "⚠️  checkov not found. Install: pip install checkov"
else
    IAC_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(tf|yml|yaml|json)$|Dockerfile' || true)
    if [ -z "$IAC_FILES" ]; then
        echo "✅ Checkov: No IaC files staged, skipping."
    else
        CHECKOV_FAIL=0
        for file in $IAC_FILES; do
            # Run with JSON output for detailed findings
            CHECKOV_OUT=$(checkov -f "$file" --output json --compact 2>/dev/null || true)
            if echo "$CHECKOV_OUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    results = data if isinstance(data, list) else [data]
    found = False
    for r in results:
        failed = r.get('results', {}).get('failed_checks', [])
        for check in failed:
            if not found:
                print('❌ Checkov found issues:')
                print('┌──────────────────────────────────────────────────────────')
                found = True
            sev = check.get('severity', 'MEDIUM')
            print(f\"│ [{sev}] {check.get('check_id','')}: {check.get('check_result',{}).get('name', check.get('name',''))}\")
            print(f\"│   File: {check.get('file_path','')}\")
            print(f\"│   Resource: {check.get('resource','')}\")
            print('│')
    if found:
        print('└──────────────────────────────────────────────────────────')
        sys.exit(1)
except: pass
" 2>/dev/null; then
                :
            else
                CHECKOV_FAIL=1
            fi
        done
        if [ $CHECKOV_FAIL -ne 0 ]; then
            FAILED=1
        else
            echo "✅ Checkov: All IaC checks passed."
        fi
    fi
fi

# --- 3. Semgrep: Static analysis (SAST) ---
echo ""
echo "🔍 [3/$TOTAL] Running Semgrep (static analysis)..."
if ! command -v semgrep &> /dev/null; then
    echo "⚠️  semgrep not found. Install: pip install semgrep"
else
    CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|js|ts|java|go|rb|php|c|cpp|cs)$' || true)
    if [ -z "$CODE_FILES" ]; then
        echo "✅ Semgrep: No code files staged, skipping."
    else
        SEMGREP_OUT=$(semgrep --config auto --json --error $CODE_FILES 2>/dev/null || true)
        if echo "$SEMGREP_OUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    results = data.get('results', [])
    if not results:
        sys.exit(0)
    print('❌ Semgrep found issues:')
    print('┌──────────────────────────────────────────────────────────')
    for r in results:
        sev = r.get('extra', {}).get('severity', 'WARNING').upper()
        print(f\"│ [{sev}] {r.get('check_id', 'unknown')}\")
        print(f\"│   File: {r.get('path', '')}:{r.get('start', {}).get('line', '?')}\")
        print(f\"│   Message: {r.get('extra', {}).get('message', '')[:80]}\")
        print('│')
    print('└──────────────────────────────────────────────────────────')
    sys.exit(1)
except: sys.exit(0)
" 2>/dev/null; then
            echo "✅ Semgrep: No issues found."
        else
            FAILED=1
        fi
    fi
fi

# --- 4. Trivy: Vulnerability scanning ---
echo ""
echo "🔍 [4/$TOTAL] Running Trivy (vulnerability scanning)..."
if ! command -v trivy &> /dev/null; then
    echo "⚠️  trivy not found. Install: brew install trivy"
else
    TRIVY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(package-lock\.json|requirements\.txt|go\.sum|Gemfile\.lock|pom\.xml|Dockerfile)' || true)
    if [ -z "$TRIVY_FILES" ]; then
        echo "✅ Trivy: No dependency/container files staged, skipping."
    else
        TRIVY_FAIL=0
        for file in $TRIVY_FILES; do
            if echo "$file" | grep -q "Dockerfile"; then
                TRIVY_OUT=$(trivy config "$file" --severity HIGH,CRITICAL --format json 2>/dev/null || true)
            else
                TRIVY_OUT=$(trivy fs "$file" --severity HIGH,CRITICAL --format json 2>/dev/null || true)
            fi
            echo "$TRIVY_OUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    results = data.get('Results', [])
    found = False
    for r in results:
        vulns = r.get('Vulnerabilities', []) + r.get('Misconfigurations', [])
        for v in vulns:
            if not found:
                print('❌ Trivy found vulnerabilities:')
                print('┌──────────────────────────────────────────────────────────')
                found = True
            sev = v.get('Severity', 'UNKNOWN')
            vid = v.get('VulnerabilityID', v.get('ID', ''))
            pkg = v.get('PkgName', v.get('Title', ''))
            print(f\"│ [{sev}] {vid}: {pkg}\")
            print(f\"│   File: $file\")
            print(f\"│   Title: {v.get('Title', '')[:60]}\")
            print('│')
    if found:
        print('└──────────────────────────────────────────────────────────')
        sys.exit(1)
except: pass
" 2>/dev/null || TRIVY_FAIL=1
        done
        if [ $TRIVY_FAIL -ne 0 ]; then
            FAILED=1
        else
            echo "✅ Trivy: No vulnerabilities found."
        fi
    fi
fi

# --- 5. Dockle: Docker best practices ---
echo ""
echo "🔍 [5/$TOTAL] Running Dockle (Docker best practices)..."
if ! command -v dockle &> /dev/null; then
    echo "⚠️  dockle not found. Install: brew install goodwithtech/r/dockle"
else
    DOCKERFILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'Dockerfile' || true)
    if [ -z "$DOCKERFILES" ]; then
        echo "✅ Dockle: No Dockerfiles staged, skipping."
    else
        LATEST_IMAGE=$(docker images --format '{{.Repository}}:{{.Tag}}' | head -1 2>/dev/null || true)
        if [ -z "$LATEST_IMAGE" ]; then
            echo "⚠️  Dockle: No Docker images found to scan. Build an image first."
        else
            DOCKLE_OUT=$(dockle --format json "$LATEST_IMAGE" 2>/dev/null || true)
            if echo "$DOCKLE_OUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    details = data.get('details', [])
    fatal = [d for d in details if d.get('level') in ('FATAL', 'WARN')]
    if not fatal:
        sys.exit(0)
    print('❌ Dockle found issues:')
    print('┌──────────────────────────────────────────────────────────')
    for d in fatal:
        sev = d.get('level', 'UNKNOWN')
        print(f\"│ [{sev}] {d.get('code', '')}: {d.get('title', '')}\")
        for alert in d.get('alerts', []):
            print(f\"│   → {alert}\")
        print('│')
    print('└──────────────────────────────────────────────────────────')
    sys.exit(1)
except: sys.exit(0)
" 2>/dev/null; then
                echo "✅ Dockle: Docker image passed checks."
            else
                FAILED=1
            fi
        fi
    fi
fi



# --- Cleanup ---
rm -f $REPORT_FILE $REPORT_FILE.gitleaks

# --- Final result ---
echo ""
if [ $FAILED -ne 0 ]; then
    echo "🚫 Security checks FAILED. Commit blocked. Fix the issues above."
    exit 1
fi

echo "🎉 All security checks passed. Proceeding with commit."
